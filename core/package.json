{
  "name": "qrtuber",
  "description": "QRTuber Core Library for Web Apps",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "compile": "tsc -p tsconfig.build.json && copyfiles src/zbar-wasm-inlined.cjs dist",
