      "default": "./dist/index.js"
    }
  },
  "devDependencies": {
    "@types/chrome": "^0.0.280",
    "copyfiles": "^2.4.1",
    "vitest": "^4.1.9",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@undecaf/zbar-wasm": "^0.11.0",
    "buttplug": "^5.0.1",
    "eventemitter3": "^5.0.1"
  }
